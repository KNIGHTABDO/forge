# -----------------------------------------------------------------------------
# Forge unified environment template (root)
# - Use this file locally for dev.
# - Copy the same keys/values into Vercel Project -> Settings -> Environment Variables.
# -----------------------------------------------------------------------------

# Base URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://forge-app-peach.vercel.app

# Gemini backend key (required)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional key pool for rotation logic (comma-separated)
# Example: key_a,key_b,key_c
GEMINI_API_KEYS=

# Model defaults
GEMINI_MODEL=gemma-4-31b-it
GITHUB_MODEL=gemini-3.1-pro-preview

# Optional explicit Gemini CLI command for backend runtime
# Leave empty to use automatic command resolution.
# Example (Windows): C:\\path\\to\\gemini.cmd
# Example (Linux): /usr/local/bin/gemini
GEMINI_CLI_COMMAND=

# GitHub integration
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=KNIGHTABDO
GITHUB_REPO=forge-apps
GITHUB_COPILOT_OAUTH_TOKEN=your_github_copilot_oauth_token_here

# Stitch API
STITCH_API_KEY=your_stitch_api_key_here

# Search providers
TAVILY_API_KEY=your_tavily_api_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_google_search_cx_here

# Firebase client SDK (web sign-in)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (server token verification)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"

# Desktop local override (used by forge-desktop Vite app)
# Keep equal to your active web backend URL for local desktop testing.
VITE_FORGE_WEB_BASE_URL=https://forge-app-peach.vercel.app