# Gemini API Keys (comma-separated for smart rotation)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub — personal access token with repo read/write scope
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=KNIGHTABDO
GITHUB_REPO=forge-apps

# Base URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://forge-app.vercel.app

STITCH_API_KEY=your_stitch_api_key_here
GITHUB_COPILOT_OAUTH_TOKEN=your_github_copilot_oauth_token_here

# Tavily Search API
TAVILY_API_KEY=your_tavily_api_key_here

# Google Custom Search API
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_google_search_cx_here